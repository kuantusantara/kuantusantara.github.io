// src/components/astro/TelemetryTable.astro
---
const openPositions = [
  { ticket: "8849201", time: "2026.05.23 14:20:15", type: "BUY", size: "1.50", symbol: "XAUUSD", open: "2345.50", sl: "2330.00", tp: "2380.00", current: "2352.25", profit: "+$1,012.50", isProfit: true },
  { ticket: "8849215", time: "2026.05.23 15:45:02", type: "SELL", size: "5.00", symbol: "EURUSD", open: "1.08550", sl: "1.09100", tp: "1.07200", current: "1.08410", profit: "+$700.00", isProfit: true }
];

const tradeHistory = [
  { ticket: "8848102", time: "2026.05.22 09:15:00", type: "BUY", size: "2.00", symbol: "NASDAQ", open: "18500.25", close: "18650.50", profit: "+$3,005.00", isProfit: true },
  { ticket: "8848095", time: "2026.05.21 18:30:45", type: "SELL", size: "1.50", symbol: "XAUUSD", open: "2360.00", close: "2364.50", profit: "-$675.00", isProfit: false },
  { ticket: "8847950", time: "2026.05.20 10:05:12", type: "BUY", size: "3.00", symbol: "EURUSD", open: "1.08100", close: "1.08650", profit: "+$1,650.00", isProfit: true }
];
---

<section id="telemetry" class="py-24 bg-[#07080A] relative z-10 border-t border-white/[0.04]">
  <div class="container mx-auto px-6 max-w-6xl">
    
    <div class="flex flex-col md:flex-row justify-between items-end mb-10 gap-6">
      <div>
        <h2 class="text-3xl font-semibold tracking-tight text-white mb-2">Live Telemetry.</h2>
        <p class="text-[14px] font-light text-zinc-400">Real-time execution data via MetaTrader 5 institutional bridge.</p>
      </div>
      
      {/* Vanilla JS Segmented Control (Apple-inspired) */}
      <div class="flex p-1 bg-white/[0.03] border border-white/[0.08] rounded-md">
        <button id="btn-open" class="px-6 py-1.5 text-[12px] font-medium text-black bg-white rounded-sm transition-all outline-none">Open Positions</button>
        <button id="btn-history" class="px-6 py-1.5 text-[12px] font-medium text-zinc-400 hover:text-white rounded-sm transition-all outline-none">Trade History</button>
      </div>
    </div>

    <div class="bg-[#0D0D0D] border border-white/[0.08] rounded-xl overflow-hidden shadow-inner">
      <div class="overflow-x-auto">
        
        {/* OPEN POSITIONS TABLE */}
        <table id="table-open" class="w-full text-left border-collapse">
          <thead>
            <tr class="border-b border-white/[0.04] bg-white/[0.01]">
              <th class="px-6 py-4 text-[10px] font-mono uppercase tracking-widest text-zinc-500 font-medium">Ticket</th>
              <th class="px-6 py-4 text-[10px] font-mono uppercase tracking-widest text-zinc-500 font-medium">Time</th>
              <th class="px-6 py-4 text-[10px] font-mono uppercase tracking-widest text-zinc-500 font-medium">Type</th>
              <th class="px-6 py-4 text-[10px] font-mono uppercase tracking-widest text-zinc-500 font-medium">Vol</th>
              <th class="px-6 py-4 text-[10px] font-mono uppercase tracking-widest text-zinc-500 font-medium">Symbol</th>
              <th class="px-6 py-4 text-[10px] font-mono uppercase tracking-widest text-zinc-500 font-medium">Open</th>
              <th class="px-6 py-4 text-[10px] font-mono uppercase tracking-widest text-zinc-500 font-medium">S/L</th>
              <th class="px-6 py-4 text-[10px] font-mono uppercase tracking-widest text-zinc-500 font-medium">T/P</th>
              <th class="px-6 py-4 text-[10px] font-mono uppercase tracking-widest text-zinc-500 font-medium">Current</th>
              <th class="px-6 py-4 text-[10px] font-mono uppercase tracking-widest text-zinc-500 font-medium text-right">Profit</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-white/[0.04]">
            {openPositions.map((pos) => (
              <tr class="hover:bg-white/[0.02] transition-colors">
                <td class="px-6 py-4 text-[13px] font-mono text-zinc-400">{pos.ticket}</td>
                <td class="px-6 py-4 text-[13px] font-mono text-zinc-400">{pos.time}</td>
                <td class={`px-6 py-4 text-[12px] font-semibold ${pos.type === 'BUY' ? 'text-emerald-400' : 'text-rose-400'}`}>{pos.type}</td>
                <td class="px-6 py-4 text-[13px] font-mono text-white">{pos.size}</td>
                <td class="px-6 py-4 text-[13px] font-medium text-white">{pos.symbol}</td>
                <td class="px-6 py-4 text-[13px] font-mono text-zinc-300">{pos.open}</td>
                <td class="px-6 py-4 text-[13px] font-mono text-zinc-500">{pos.sl}</td>
                <td class="px-6 py-4 text-[13px] font-mono text-zinc-500">{pos.tp}</td>
                <td class="px-6 py-4 text-[13px] font-mono text-white">{pos.current}</td>
                <td class={`px-6 py-4 text-[14px] font-mono text-right ${pos.isProfit ? 'text-emerald-400' : 'text-rose-400'}`}>{pos.profit}</td>
              </tr>
            ))}
          </tbody>
        </table>

        {/* TRADE HISTORY TABLE (Hidden by default) */}
        <table id="table-history" class="w-full text-left border-collapse hidden">
          <thead>
            <tr class="border-b border-white/[0.04] bg-white/[0.01]">
              <th class="px-6 py-4 text-[10px] font-mono uppercase tracking-widest text-zinc-500 font-medium">Ticket</th>
              <th class="px-6 py-4 text-[10px] font-mono uppercase tracking-widest text-zinc-500 font-medium">Time (Closed)</th>
              <th class="px-6 py-4 text-[10px] font-mono uppercase tracking-widest text-zinc-500 font-medium">Type</th>
              <th class="px-6 py-4 text-[10px] font-mono uppercase tracking-widest text-zinc-500 font-medium">Vol</th>
              <th class="px-6 py-4 text-[10px] font-mono uppercase tracking-widest text-zinc-500 font-medium">Symbol</th>
              <th class="px-6 py-4 text-[10px] font-mono uppercase tracking-widest text-zinc-500 font-medium">Open</th>
              <th class="px-6 py-4 text-[10px] font-mono uppercase tracking-widest text-zinc-500 font-medium">Close</th>
              <th class="px-6 py-4 text-[10px] font-mono uppercase tracking-widest text-zinc-500 font-medium text-right">Final Profit</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-white/[0.04]">
            {tradeHistory.map((pos) => (
              <tr class="hover:bg-white/[0.02] transition-colors">
                <td class="px-6 py-4 text-[13px] font-mono text-zinc-400">{pos.ticket}</td>
                <td class="px-6 py-4 text-[13px] font-mono text-zinc-400">{pos.time}</td>
                <td class={`px-6 py-4 text-[12px] font-semibold ${pos.type === 'BUY' ? 'text-emerald-400' : 'text-rose-400'}`}>{pos.type}</td>
                <td class="px-6 py-4 text-[13px] font-mono text-white">{pos.size}</td>
                <td class="px-6 py-4 text-[13px] font-medium text-white">{pos.symbol}</td>
                <td class="px-6 py-4 text-[13px] font-mono text-zinc-300">{pos.open}</td>
                <td class="px-6 py-4 text-[13px] font-mono text-zinc-300">{pos.close}</td>
                <td class={`px-6 py-4 text-[14px] font-mono text-right ${pos.isProfit ? 'text-emerald-400' : 'text-rose-400'}`}>{pos.profit}</td>
              </tr>
            ))}
          </tbody>
        </table>

      </div>
    </div>
  </div>
</section>

<script>
  // Pure Vanilla JS for tab switching - zero framework overhead
  const btnOpen = document.getElementById('btn-open');
  const btnHistory = document.getElementById('btn-history');
  const tableOpen = document.getElementById('table-open');
  const tableHistory = document.getElementById('table-history');

  const activeClass = ['bg-white', 'text-black'];
  const inactiveClass = ['text-zinc-400', 'bg-transparent'];

  btnOpen?.addEventListener('click', () => {
    tableOpen?.classList.remove('hidden');
    tableHistory?.classList.add('hidden');
    
    btnOpen.classList.add(...activeClass);
    btnOpen.classList.remove(...inactiveClass);
    
    btnHistory?.classList.remove(...activeClass);
    btnHistory?.classList.add(...inactiveClass);
  });

  btnHistory?.addEventListener('click', () => {
    tableHistory?.classList.remove('hidden');
    tableOpen?.classList.add('hidden');
    
    btnHistory.classList.add(...activeClass);
    btnHistory.classList.remove(...inactiveClass);
    
    btnOpen?.classList.remove(...activeClass);
    btnOpen?.classList.add(...inactiveClass);
  });
</script>