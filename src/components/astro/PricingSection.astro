// src/components/astro/PricingSection.astro
---
const pricingTiers = [
  {
    duration: "3 Months",
    tier: "Quarterly",
    label: "Retail Standard",
    description: "Lisensi tunggal (Single EA) untuk EURUSD, XAUUSD, atau NASDAQ. Ideal untuk evaluasi dan forward-testing.",
    price: "Custom",
    features: [
      "1 Live Trading Account",
      "Standard Execution Telemetry",
      "Strict Risk Parameters",
      "No Grid / No Martingale"
    ],
    cta: "Contact Admin",
    highlight: false
  },
  {
    duration: "6 Months",
    tier: "Biannual",
    label: "Pro Trader",
    description: "Lisensi tunggal (Single EA). Nilai optimal dengan potongan harga khusus untuk afiliasi broker.",
    price: "Custom",
    features: [
      "1 Live Trading Account",
      "Advanced Execution Telemetry",
      "Priority System Support",
      "Broker Affiliate Discount (MRG, dll)"
    ],
    cta: "Request Allocation",
    highlight: true
  },
  {
    duration: "12 Months",
    tier: "Annual",
    label: "Institutional License",
    description: "Lisensi tunggal (Single EA). Didedikasikan untuk investor jangka panjang dan pengelola dana.",
    price: "Custom",
    features: [
      "Up to 2 Live Accounts",
      "Full Data Telemetry",
      "Direct Architect Access",
      "Maximum Affiliate Discount"
    ],
    cta: "Contact Desks",
    highlight: false
  }
];
---

<section id="pricing" class="py-24 bg-[#07080A] relative z-10 border-t border-white/[0.04]">
  <div class="container mx-auto px-6 max-w-6xl">
    
    <div class="text-center mb-16">
      <h2 class="text-4xl font-semibold tracking-tight text-white mb-4">Deployment Allocation.</h2>
      <p class="text-[14px] font-light text-zinc-400 leading-relaxed max-w-2xl mx-auto">
        Infrastruktur EA Kuantusantara disewakan secara eksklusif per instrumen. Skema harga khusus tersedia bagi entitas yang terafiliasi dengan pialang eksekusi mitra kami.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {pricingTiers.map((tier) => (
        <article class={`relative bg-[#0D0D0D] rounded-xl p-8 transition-all duration-300 overflow-hidden flex flex-col ${tier.highlight ? 'border border-white/[0.15] shadow-[0_0_40px_rgba(255,255,255,0.03)] scale-[1.02]' : 'border border-white/[0.08] hover:border-white/[0.15]'}`}>
          
          {/* Highlight Glow for Center Card */}
          {tier.highlight && (
            <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full h-1/2 bg-white/[0.02] blur-[50px] pointer-events-none"></div>
          )}

          <div class="mb-8 relative z-10">
            <div class="flex justify-between items-start mb-4">
              <span class="text-[10px] font-mono uppercase tracking-widest text-zinc-500">{tier.tier}</span>
              {tier.highlight && (
                <span class="text-[10px] font-mono uppercase tracking-widest text-black bg-white px-2 py-0.5 rounded-sm">Recommended</span>
              )}
            </div>
            <h3 class="text-2xl font-semibold text-white mb-2">{tier.duration}</h3>
            <p class="text-[14px] font-medium text-white mb-2">{tier.label}</p>
            <p class="text-[13px] font-light text-zinc-400 leading-relaxed h-12">{tier.description}</p>
          </div>

          <div class="mb-8 relative z-10">
            <div class="flex items-baseline gap-2 border-b border-white/[0.04] pb-6">
              <span class="text-3xl font-mono text-white tracking-tight">{tier.price}</span>
              <span class="text-[12px] font-mono text-zinc-500">/ EA</span>
            </div>
          </div>

          <ul class="space-y-4 mb-10 flex-grow relative z-10">
            {tier.features.map((feature) => (
              <li class="flex items-start gap-3">
                <svg class="w-4 h-4 text-white mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                <span class="text-[13px] font-light text-zinc-300">{feature}</span>
              </li>
            ))}
          </ul>

          <a href="https://wa.me/your_admin_number" class={`relative z-10 w-full py-3 text-center rounded-md text-[13px] font-medium transition-all outline-none focus:ring-2 focus:ring-white/20 ${tier.highlight ? 'bg-white text-black hover:bg-zinc-200 hover:scale-[0.98]' : 'bg-transparent text-white border border-white/[0.15] hover:bg-white/[0.05]'}`}>
            {tier.cta}
          </a>
        </article>
      ))}
    </div>

  </div>
</section>