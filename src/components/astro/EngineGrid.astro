// src/components/astro/EngineGrid.astro
---
const engines = [
  {
    asset: "XAUUSD",
    strategy: "Volatility Edge / Precision Swing",
    sharpeRatio: "2.84",
    sortinoRatio: "4.15",
    maxDrawdown: "4.82%",
    recoveryFactor: "6.5",
    monthlyAlpha: "3.20%",
    validation: "98.5% Monte Carlo (NVIDIA DGX Spark)",
    protocols: ["Strict Pending Orders", "Volatility-Adjusted Sizing", "Zero Martingale"]
  },
  {
    asset: "EURUSD",
    strategy: "Macro Trend / Institutional Swing",
    sharpeRatio: "2.12",
    sortinoRatio: "3.05",
    maxDrawdown: "3.15%",
    recoveryFactor: "5.2",
    monthlyAlpha: "1.85%",
    validation: "99.1% Monte Carlo (NVIDIA DGX Spark)",
    protocols: ["Strict Pending Orders", "Dynamic Stop-Loss", "Zero Grid"]
  },
  {
    asset: "NASDAQ",
    strategy: "Momentum Capture / Index Swing",
    sharpeRatio: "2.45",
    sortinoRatio: "3.60",
    maxDrawdown: "6.20%",
    recoveryFactor: "8.1",
    monthlyAlpha: "4.15%",
    validation: "97.8% Monte Carlo (NVIDIA DGX Spark)",
    protocols: ["Strict Pending Orders", "Session-Specific Routing", "Zero Martingale"]
  }
];
---

<section id="engines" class="py-24 bg-[#07080A] relative z-10 border-t border-white/[0.04]">
  <div class="container mx-auto px-6">
    <div class="mb-20 text-center">
      <h2 class="text-4xl font-semibold tracking-tight text-white mb-4">Quantitative Engines.</h2>
      <p class="text-[14px] font-light text-zinc-400 leading-relaxed max-w-2xl mx-auto">
        Institutional-grade execution logic. Validated through rigorous out-of-sample stress testing and deployed with absolute risk parameters.
      </p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 max-w-6xl mx-auto">
      {engines.map((engine) => (
        <article class="bg-[#0D0D0D] border border-white/[0.08] rounded-xl p-8 hover:border-white/[0.15] transition-colors group relative overflow-hidden">
          
          {/* Card Header */}
          <div class="mb-8 border-b border-white/[0.04] pb-6">
            <div class="flex justify-between items-start mb-3">
              <h3 class="text-[17px] font-medium text-white">{engine.asset}</h3>
              <span class="text-[10px] font-mono uppercase tracking-widest text-emerald-400 bg-emerald-500/10 px-2.5 py-1 rounded-full">Active</span>
            </div>
            <p class="text-[14px] font-light text-zinc-400">{engine.strategy}</p>
          </div>

          {/* Core Metrics Grid */}
          <div class="grid grid-cols-2 gap-y-8 gap-x-4 mb-8">
            <div>
              <p class="text-[10px] font-mono uppercase tracking-widest text-zinc-500 mb-1.5">Sharpe Ratio</p>
              <p class="text-xl font-mono text-white tracking-tight">{engine.sharpeRatio}</p>
            </div>
            <div>
              <p class="text-[10px] font-mono uppercase tracking-widest text-zinc-500 mb-1.5">Sortino Ratio</p>
              <p class="text-xl font-mono text-white tracking-tight">{engine.sortinoRatio}</p>
            </div>
            <div>
              <p class="text-[10px] font-mono uppercase tracking-widest text-zinc-500 mb-1.5">Max Drawdown</p>
              <p class="text-xl font-mono text-white tracking-tight">{engine.maxDrawdown}</p>
            </div>
            <div>
              <p class="text-[10px] font-mono uppercase tracking-widest text-zinc-500 mb-1.5">Monthly Alpha</p>
              <p class="text-xl font-mono text-white tracking-tight">{engine.monthlyAlpha}</p>
            </div>
          </div>

          {/* Validation & Safety */}
          <div class="space-y-6 pt-6 border-t border-white/[0.04]">
            <div>
              <p class="text-[10px] font-mono uppercase tracking-widest text-zinc-500 mb-2">System Validation</p>
              <p class="text-[13px] font-light text-zinc-400">{engine.validation}</p>
            </div>
            <div>
              <p class="text-[10px] font-mono uppercase tracking-widest text-zinc-500 mb-3">Safety Protocols</p>
              <ul class="space-y-2.5">
                {engine.protocols.map((protocol) => (
                  <li class="text-[13px] font-light text-zinc-400 flex items-center gap-3">
                    <span class="w-1 h-1 bg-white/[0.2] rounded-full"></span>
                    {protocol}
                  </li>
                ))}
              </ul>
            </div>
          </div>
          
        </article>
      ))}
    </div>
  </div>
</section>